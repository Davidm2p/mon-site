---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const SITE_TITLE = 'Accompagnements — M²P Coaching & Développement';
const SITE_DESCRIPTION = 'Coaching professionnel certifié pour professionnels et particuliers.';
---
<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="aig-hero">
        <div class="aig-inner">
          <p class="aig-surtitre">LES ACCOMPAGNEMENTS M²P</p>
          <h1>De qui s'agit-il ?</h1>
          <p class="aig-intro">Le cadre de travail est le même. La situation, les enjeux et les tarifs diffèrent. Choisissez ce qui correspond à votre réalité.</p>
        </div>
      </section>
      <section class="aig-choix">
        <div class="aig-grid">
          <a href="/professionnels" class="aig-carte">
            <p class="aig-carte-label">CADRES · MANAGERS · DIRIGEANTS · DRH</p>
            <h2>Vous êtes un professionnel ou une organisation</h2>
            <p>Prise de poste, surcharge décisionnelle, accompagnement de managers promus, direction d'établissements de santé. Tarifs HT, contrat tripartite possible.</p>
            <span class="aig-carte-cta">Voir les accompagnements professionnels</span>
          </a>
          <a href="/particuliers" class="aig-carte aig-carte--alt">
            <p class="aig-carte-label">PARTICULIERS</p>
            <h2>Vous cherchez un accompagnement pour vous-même</h2>
            <p>Vous êtes à un tournant. Votre travail ne vous correspond plus. Vous voulez avancer par vous-même, sans que cela implique votre employeur.</p>
            <span class="aig-carte-cta">Voir les accompagnements particuliers</span>
          </a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
.aig-hero { background: #2d3328; color: #f5f2eb; padding: 5rem 2rem 4rem; text-align: center; }
.aig-inner { max-width: 700px; margin: 0 auto; }
.aig-surtitre { font-size: 0.75rem; letter-spacing: 0.15em; color: #C18E52; text-transform: uppercase; font-weight: 600; margin-bottom: 1rem; }
.aig-hero h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; margin-bottom: 1.25rem; }
.aig-intro { font-size: 1.05rem; color: #c8dcd0; line-height: 1.7; }
.aig-choix { background: #f5f2eb; padding: 5rem 2rem; }
.aig-grid { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem; }
.aig-carte { display: block; background: #fff; border-top: 4px solid #C18E52; padding: 2.5rem 2rem; text-decoration: none; color: inherit; border-radius: 2px; transition: transform 0.2s, box-shadow 0.2s; }
.aig-carte:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
.aig-carte--alt { border-top-color: #6E8774; }
.aig-carte-label { font-size: 0.72rem; letter-spacing: 0.12em; color: #C18E52; text-transform: uppercase; font-weight: 600; margin-bottom: 0.75rem; }
.aig-carte--alt .aig-carte-label { color: #6E8774; }
.aig-carte h2 { font-size: 1.3rem; font-weight: 700; color: #2d3328; margin-bottom: 1rem; line-height: 1.3; }
.aig-carte p { font-size: 0.92rem; color: #4a4f4b; line-height: 1.7; margin-bottom: 1.5rem; }
.aig-carte-cta { font-size: 0.88rem; font-weight: 600; color: #C18E52; text-decoration: underline; }
.aig-carte--alt .aig-carte-cta { color: #6E8774; }
</style>
