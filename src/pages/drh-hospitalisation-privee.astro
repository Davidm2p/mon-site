---
import BaseHead from '../components/BaseHead.astro';

const SITE_TITLE = "Coaching DRH Hospitalisation Privée | M²P Coaching";
const SITE_DESCRIPTION = "Coaching professionnel certifié RNCP 6 pour les DRH de l'hospitalisation privée. Sécurisez vos prises de poste, stabilisez vos cadres en tension. David Delord, 22 ans de terrain RH.";
const TCP = "https://thecoachpilot.com/book/david-delord/echange-decouverte-30-min-m-p-coaching";
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Atkinson Hyperlegible', system-ui, sans-serif;
        background: #F4F1EA;
        color: #535861;
        line-height: 1.6;
      }

      .lp-header {
        background: #535861;
        padding: 0.875rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .lp-logo img { height: 48px; display: block; }
      .lp-cta {
        background: #C99763;
        color: #fff;
        font-family: 'Atkinson Hyperlegible', system-ui, sans-serif;
        font-size: 13px;
        font-weight: 700;
        padding: 10px 20px;
        border-radius: 0.5rem;
        text-decoration: none;
        white-space: nowrap;
      }

      .hero { background: #535861; padding: 3rem 2rem 2.5rem; }
      .hero-inner { max-width: 680px; margin: 0 auto; }
      .hero-tag {
        display: inline-block;
        background: #C99763;
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        padding: 5px 14px;
        border-radius: 0.5rem;
        margin-bottom: 1.5rem;
      }
      .hero h1 {
        font-size: 26px;
        font-weight: 700;
        color: #F4F1EA;
        line-height: 1.35;
        margin-bottom: 1.25rem;
      }
      .hero-sub {
        font-size: 16px;
        color: #A8B8A2;
        line-height: 1.75;
        margin-bottom: 2rem;
      }
      .btn-primary {
        display: inline-block;
        background: #C99763;
        color: #fff;
        font-family: 'Atkinson Hyperlegible', system-ui, sans-serif;
        font-size: 15px;
        font-weight: 700;
        padding: 14px 28px;
        border-radius: 0.5rem;
        text-decoration: none;
      }
      .hero-proof {
        display: flex;
        gap: 2.5rem;
        margin-top: 2rem;
        padding-top: 1.75rem;
        border-top: 1px solid rgba(168,184,162,0.2);
        flex-wrap: wrap;
      }
      .proof-val {
        display: block;
        font-size: 18px;
        font-weight: 700;
        color: #F4F1EA;
        margin-bottom: 3px;
      }
      .proof-lbl { font-size: 12px; color: #A8B8A2; }

      .wrap { max-width: 680px; margin: 0 auto; padding: 2.5rem 2rem; }
      .eyebrow {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #C99763;
        margin-bottom: 0.75rem;
      }
      h2 {
        font-size: 20px;
        font-weight: 700;
        color: #535861;
        line-height: 1.35;
        margin-bottom: 1.5rem;
      }
      .bg-creme { background: #F4F1EA; }
      .bg-white { background: #ffffff; }
      .sep { border: none; border-top: 1px solid #E0DDD6; margin: 0; }

      .pain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      .pain-card {
        background: #fff;
        border: 1px solid #E0DDD6;
        border-radius: 0.5rem;
        padding: 16px;
        font-size: 14px;
        color: #535861;
        line-height: 1.6;
      }

      .ben-list { display: flex; flex-direction: column; gap: 12px; }
      .ben-item {
        display: flex;
        gap: 16px;
        align-items: flex-start;
        background: #F4F1EA;
        border: 1px solid #E0DDD6;
        border-radius: 0.75rem;
        padding: 16px;
      }
      .ben-icon {
        width: 40px; height: 40px; min-width: 40px;
        border-radius: 0.5rem;
        background: #EDD9B4;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
      }
      .ben-body h3 { font-size: 15px; font-weight: 700; color: #535861; margin-bottom: 5px; }
      .ben-body p { font-size: 13px; color: #535861; line-height: 1.65; }

      .trig-list { display: flex; flex-direction: column; gap: 10px; }
      .trig-item {
        display: flex; gap: 14px; align-items: flex-start;
        background: #fff; border: 1px solid #E0DDD6;
        border-radius: 0.5rem; padding: 14px 16px;
      }
      .trig-arrow { color: #C99763; font-size: 18px; font-weight: 700; flex-shrink: 0; margin-top: 1px; }
      .trig-item p { font-size: 14px; color: #535861; line-height: 1.6; }

      .parcours-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
      .parcours-card {
        background: #fff; border: 1px solid #E0DDD6;
        border-radius: 0.75rem; padding: 18px 14px;
      }
      .parcours-card.star { border: 2px solid #C99763; }
      .parcours-label {
        font-size: 10px; font-weight: 700; letter-spacing: 0.07em;
        text-transform: uppercase; color: #C99763; margin-bottom: 8px;
      }
      .parcours-card h3 { font-size: 14px; font-weight: 700; color: #535861; line-height: 1.35; margin-bottom: 8px; }
      .parcours-seances { font-size: 12px; color: #7F9B88; margin-bottom: 10px; }
      .parcours-prix { font-size: 20px; font-weight: 700; color: #535861; }
      .parcours-prix span { font-size: 12px; font-weight: 400; color: #7F9B88; }
      .parcours-desc { font-size: 12px; color: #535861; line-height: 1.6; margin-top: 10px; }
      .parcours-note { font-size: 12px; color: #7F9B88; margin-top: 14px; }

      .process-list { display: flex; flex-direction: column; }
      .process-step { display: flex; gap: 18px; padding: 18px 0; border-bottom: 1px solid #E0DDD6; }
      .process-step:last-child { border-bottom: none; }
      .step-num {
        width: 32px; height: 32px; min-width: 32px;
        border-radius: 50%; background: #EDD9B4;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: 700; color: #7A5020; margin-top: 2px;
      }
      .step-body h3 { font-size: 15px; font-weight: 700; color: #535861; margin-bottom: 5px; }
      .step-body p { font-size: 13px; color: #535861; line-height: 1.65; }

      .david-block {
        display: flex; gap: 18px; align-items: flex-start;
        background: #F4F1EA; border: 1px solid #E0DDD6;
        border-radius: 0.75rem; padding: 20px;
      }
      .david-avatar {
        width: 52px; height: 52px; min-width: 52px;
        border-radius: 50%; background: #7F9B88;
        display: flex; align-items: center; justify-content: center;
        font-size: 16px; font-weight: 700; color: #F4F1EA;
      }
      .david-body h3 { font-size: 15px; font-weight: 700; color: #535861; margin-bottom: 8px; }
      .david-body p { font-size: 13px; color: #535861; line-height: 1.65; }
      .david-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
      .david-tag {
        font-size: 11px; padding: 4px 10px; border-radius: 0.5rem;
        background: #EDD9B4; color: #7A5020; font-weight: 600;
      }

      .cta-section { background: #535861; padding: 3rem 2rem; text-align: center; }
      .cta-inner { max-width: 520px; margin: 0 auto; }
      .cta-section h2 { font-size: 22px; font-weight: 700; color: #F4F1EA; margin-bottom: 1rem; }
      .cta-section p { font-size: 15px; color: #A8B8A2; line-height: 1.75; margin-bottom: 2rem; }
      .cta-sub { font-size: 12px; color: #A8B8A2; margin-top: 1.25rem; }

      .lp-footer {
        background: #535861;
        border-top: 1px solid rgba(168,184,162,0.15);
        padding: 1.25rem 2rem;
        text-align: center;
        font-size: 12px;
        color: #A8B8A2;
      }
      .lp-footer a { color: #C99763; text-decoration: none; }

      @media (max-width: 600px) {
        .hero h1 { font-size: 20px; }
        .hero-proof { gap: 1.25rem; }
        .pain-grid { grid-template-columns: 1fr; }
        .parcours-grid { grid-template-columns: 1fr; }
        .wrap { padding: 2rem 1.25rem; }
        .hero { padding: 2rem 1.25rem; }
        .cta-section { padding: 2rem 1.25rem; }
      }
    </style>
  </head>
  <body>

    <header class="lp-header">
      <a href="/" class="lp-logo"><img src="/logo.png" alt="M²P Coaching et Développement" /></a>
      <a href={TCP} target="_blank" rel="noopener" class="lp-cta">Réserver 30 min &rarr;</a>
    </header>

    <section class="hero">
      <div class="hero-inner">
        <div class="hero-tag">DRH &middot; Hospitalisation privée</div>
        <h1>Vos managers clés décrochent avant même que vous le voyiez venir.</h1>
        <p class="hero-sub">Un coaching expert, ancré dans les réalités de la santé privée, pour sécuriser vos prises de poste, stabiliser vos cadres en tension et réduire le coût humain des décrochages précoces.</p>
        <a href={TCP} target="_blank" rel="noopener" class="btn-primary">Réserver un échange de 30 min &rarr;</a>
        <div class="hero-proof">
          <div class="proof-item"><span class="proof-val">22 ans</span><span class="proof-lbl">Expérience RH terrain</span></div>
          <div class="proof-item"><span class="proof-val">RNCP 6</span><span class="proof-lbl">Certification coach</span></div>
          <div class="proof-item"><span class="proof-val">Santé privée</span><span class="proof-lbl">Secteur connu de l'intérieur</span></div>
        </div>
      </div>
    </section>

    <section class="bg-creme">
      <div class="wrap">
        <p class="eyebrow">Ce que vous gérez en ce moment</p>
        <h2>Vous connaissez ces situations. Elles coûtent cher à ne pas traiter.</h2>
        <div class="pain-grid">
          <div class="pain-card">Un manager promu qui perd pied dans les 12 premiers mois. Son équipe le sent avant que vous le sachiez.</div>
          <div class="pain-card">Un directeur d'établissement sous pression groupe qui absorbe tout sans le dire. Jusqu'au jour où il ne peut plus.</div>
          <div class="pain-card">Une prise de poste stratégique que vous voulez sécuriser. Mais vous n'avez pas de ressource interne disponible.</div>
          <div class="pain-card">Un cadre de santé compétent, loyal, qui commence à décrocher. Le remplacer vous coûterait entre 6 et 18 mois de salaire.</div>
        </div>
      </div>
    </section>

    <hr class="sep" />

    <section class="bg-white">
      <div class="wrap">
        <p class="eyebrow">Ce que j'apporte</p>
        <h2>Un cadre d'intervention taillé pour votre contexte.</h2>
        <div class="ben-list">
          <div class="ben-item">
            <div class="ben-icon">🏥</div>
            <div class="ben-body">
              <h3>Je connais le secteur de l'intérieur</h3>
              <p>22 ans en ressources humaines, dont une expérience directe dans la santé privée multi-sites. Pression ARS, turn-over soignant, dictature de l'urgence : je n'ai pas besoin qu'on me les explique. On va droit au sujet.</p>
            </div>
          </div>
          <div class="ben-item">
            <div class="ben-icon">🔒</div>
            <div class="ben-body">
              <h3>Cadre tripartite sécurisé</h3>
              <p>Vous définissez l'objectif institutionnel. Votre collaborateur travaille dans un espace confidentiel total. L'étanchéité entre les séances et l'organisation est contractuellement garantie.</p>
            </div>
          </div>
          <div class="ben-item">
            <div class="ben-icon">📈</div>
            <div class="ben-body">
              <h3>Des résultats mesurables dès le mi-parcours</h3>
              <p>Un point de mi-parcours vous permet d'évaluer la progression sans entrer dans le contenu des séances. Vous investissez sur un profil, vous suivez l'évolution. Pas de boîte noire.</p>
            </div>
          </div>
          <div class="ben-item">
            <div class="ben-icon">🎓</div>
            <div class="ben-body">
              <h3>Certification et supervision</h3>
              <p>Coach certifié RNCP niveau 6. Pratique supervisée mensuellement. Charte Éthique du Coaching respectée. Une prestation que vous pouvez présenter à votre direction comme un investissement sécurisé.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <hr class="sep" />

    <section class="bg-creme">
      <div class="wrap">
        <p class="eyebrow">Situations d'intervention</p>
        <h2>Quand est-ce que vous faites appel à moi ?</h2>
        <div class="trig-list">
          <div class="trig-item"><span class="trig-arrow">&rarr;</span><p>Un manager promu qui montre les premiers signes de décrochage, avant que ça devienne visible pour les équipes.</p></div>
          <div class="trig-item"><span class="trig-arrow">&rarr;</span><p>Un directeur d'établissement ou directeur adjoint en prise de poste que vous voulez sécuriser dans les 90 premiers jours.</p></div>
          <div class="trig-item"><span class="trig-arrow">&rarr;</span><p>Un cadre de santé en tension posturale que vous voulez retenir. Compétent, mais à bout.</p></div>
          <div class="trig-item"><span class="trig-arrow">&rarr;</span><p>Un plan de développement RH à construire pour mobiliser une enveloppe formation sur des profils prioritaires.</p></div>
        </div>
      </div>
    </section>

    <hr class="sep" />

    <section class="bg-white">
      <div class="wrap">
        <p class="eyebrow">Les parcours M²P</p>
        <h2>Trois niveaux selon la situation.</h2>
        <div class="parcours-grid">
          <div class="parcours-card">
            <div class="parcours-label">Maîtrise</div>
            <h3>De la surcharge à la clarté</h3>
            <div class="parcours-seances">6 séances</div>
            <div class="parcours-prix">1 800 € <span>HT &middot; 300 €/séance</span></div>
            <p class="parcours-desc">Nommer ce qui se passe. Réduire la pression. Retrouver des appuis solides.</p>
          </div>
          <div class="parcours-card star">
            <div class="parcours-label">Mouvement</div>
            <h3>De la clarté à la décision assumée</h3>
            <div class="parcours-seances">8 séances</div>
            <div class="parcours-prix">2 200 € <span>HT &middot; 275 €/séance</span></div>
            <p class="parcours-desc">Les ressources émergent. Les décisions se prennent. Adapté aux prises de poste et tensions actives.</p>
          </div>
          <div class="parcours-card">
            <div class="parcours-label">Progression</div>
            <h3>De la décision à la posture tenue</h3>
            <div class="parcours-seances">10 séances</div>
            <div class="parcours-prix">2 500 € <span>HT &middot; 250 €/séance</span></div>
            <p class="parcours-desc">Ancrer un leadership durable. Sans dépendre d'un cadre extérieur.</p>
          </div>
        </div>
        <p class="parcours-note">40% à la signature &middot; 30% mi-parcours &middot; 30% dernière séance.</p>
      </div>
    </section>

    <hr class="sep" />

    <section class="bg-creme">
      <div class="wrap">
        <p class="eyebrow">Comment ça fonctionne</p>
        <h2>Du premier contact à la fin du parcours.</h2>
        <div class="process-list">
          <div class="process-step">
            <div class="step-num">1</div>
            <div class="step-body"><h3>Échange de 30 minutes</h3><p>Vous décrivez la situation. Je qualifie si le coaching est la bonne réponse. On pose le cadre contractuel tripartite. Sans engagement.</p></div>
          </div>
          <div class="process-step">
            <div class="step-num">2</div>
            <div class="step-body"><h3>Entretien préalable avec le coaché</h3><p>Je rencontre votre collaborateur. On vérifie ensemble la coachabilité de la situation. Si ce n'est pas le bon moment, je vous le dis.</p></div>
          </div>
          <div class="process-step">
            <div class="step-num">3</div>
            <div class="step-body"><h3>Parcours en séances individuelles</h3><p>45 à 60 minutes par séance, en visio ou en présentiel en Occitanie. Confidentialité totale. Flexibilité calendaire adaptée aux contraintes du secteur.</p></div>
          </div>
          <div class="process-step">
            <div class="step-num">4</div>
            <div class="step-body"><h3>Point de mi-parcours avec vous</h3><p>Un bilan intermédiaire sur la progression observable. Vous mesurez l'impact sur la posture et le fonctionnement dans le rôle, sans entrer dans le contenu des séances.</p></div>
          </div>
        </div>
      </div>
    </section>

    <hr class="sep" />

    <section class="bg-white">
      <div class="wrap">
        <p class="eyebrow">Qui je suis</p>
        <h2>Pas un coach qui découvre le secteur santé.</h2>
        <div class="david-block">
          <div class="david-avatar">DD</div>
          <div class="david-body">
            <h3>David Delord &middot; Coach Professionnel Certifié RNCP 6</h3>
            <p>22 ans en ressources humaines. Consultant senior chez Randstad, puis Responsable RH Recrutement et Développement dans un groupe de santé privée multi-sites. J'ai travaillé aux côtés des directeurs d'établissements sur leurs enjeux managériaux, et siégé pendant 15 ans dans des instances représentatives du personnel. Je connais la réalité de votre secteur des deux côtés de la table.</p>
            <div class="david-tags">
              <span class="david-tag">Randstad 22 ans</span>
              <span class="david-tag">Santé privée multi-sites</span>
              <span class="david-tag">RNCP Niveau 6</span>
              <span class="david-tag">Certifié PCM</span>
              <span class="david-tag">Supervisé mensuellement</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="cta-inner">
        <h2>Parlons de votre situation.</h2>
        <p>Un échange de 30 minutes, sans engagement, pour qualifier ensemble si le coaching est la bonne réponse et quel profil prioriser.</p>
        <a href={TCP} target="_blank" rel="noopener" class="btn-primary">Réserver l'échange de 30 min &rarr;</a>
        <p class="cta-sub">Visio France entière &middot; Présentiel Occitanie &middot; david.delord@m2p-coaching.fr</p>
      </div>
    </section>

    <footer class="lp-footer">
      M²P Coaching &amp; Développement &middot; SASU &middot; RC Pro &middot;
      <a href="/">Retour au site</a> &middot;
      <a href="mailto:david.delord@m2p-coaching.fr">david.delord@m2p-coaching.fr</a>
    </footer>

  </body>
</html>