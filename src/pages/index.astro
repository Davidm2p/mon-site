---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
const SITE_TITLE = 'M²P Coaching & Développement';
const SITE_DESCRIPTION = 'Coach professionnel certifié RNCP 6 — Cadres, managers et dirigeants — Occitanie et visio France entière';
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <!-- HERO -->
      <section class="hero">
        <div class="hero-inner">
          <div class="hero-texte">
            <p class="surtitre">Coach Professionnel Certifié RNCP 6 · 22 ans de direction RH</p>
            <h1>Vous gérez tout.<br/>Sauf votre propre trajectoire.</h1>
            <p class="sous-titre">Je ne décide pas à votre place. Je crée le cadre dans lequel vous trouvez votre direction.</p>
            <a href="https://calendly.com/david-delord-m2p-coaching/30min" target="_blank" rel="noopener" class="cta">
              Envie d'en savoir plus ? 30 minutes suffisent.
            </a>
            <p class="cta-note">Sans engagement · Visio ou présentiel Occitanie</p>
          </div>
          <div class="hero-photo-wrap">
            <img src="/david.jpg" alt="David Delord, Coach Professionnel Certifié RNCP 6" class="hero-photo" width="420" height="520" loading="eager" />
            <div class="hero-badge">
              <span class="badge-titre">RNCP Niveau 6</span>
              <span class="badge-sous">Coach Certifié</span>
            </div>
          </div>
        </div>
      </section>

      <!-- DIAGNOSTIC -->
      <section class="diagnostic">
        <div class="container">
          <p class="section-label">Et vous, où en êtes-vous ?</p>
          <div class="diag-wrap">
            <div class="diag-header">
              <p class="diag-label">Auto-diagnostic</p>
              <p class="diag-titre">Quatre questions. Un profil. Une direction.</p>
              <div class="diag-progress"><div id="diag-bar"></div></div>
            </div>
            <div id="diag-quiz">
              <p id="diag-num" class="diag-num"></p>
              <p id="diag-question" class="diag-question"></p>
              <div id="diag-options" class="diag-options"></div>
              <div class="diag-nav">
                <button id="diag-back" class="diag-btn-back" onclick="diagBack()">Retour</button>
                <button id="diag-next" class="diag-btn-next" onclick="diagNext()" disabled>Continuer</button>
              </div>
            </div>
            <div id="diag-result" style="display:none">
              <div class="diag-result-card">
                <span id="diag-tag" class="diag-tag"></span>
                <p id="diag-rtitle" class="diag-rtitle"></p>
                <p id="diag-rdesc" class="diag-rdesc"></p>
                <p id="diag-rphrase" class="diag-rphrase"></p>
              </div>
              <a href="https://calendly.com/david-delord-m2p-coaching/30min" target="_blank" rel="noopener" class="diag-cta">
                Envie d'en savoir plus ? 30 minutes suffisent.
              </a>
              <p class="diag-cta-note">Sans engagement · Visio ou présentiel Occitanie</p>
              <button class="diag-restart" onclick="diagRestart()">Recommencer le diagnostic</button>
            </div>
          </div>
        </div>
      </section>

      <!-- MÉTHODE -->
      <section class="methode">
        <div class="container">
          <p class="section-label">La méthode</p>
          <h2>M²P — Maîtrise. Mouvement. Progression.</h2>
          <div class="m2p-trio">
            <div class="m2p-item">
              <div class="m2p-cercle">M</div>
              <h3>Maîtrise</h3>
              <p>Retrouver l'assise. De la saturation à la clarté.</p>
            </div>
            <div class="m2p-fleche">→</div>
            <div class="m2p-item">
              <div class="m2p-cercle">M</div>
              <h3>Mouvement</h3>
              <p>Passer à l'action juste. Vos solutions, pas les miennes.</p>
            </div>
            <div class="m2p-fleche">→</div>
            <div class="m2p-item">
              <div class="m2p-cercle">P</div>
              <h3>Progression</h3>
              <p>Tenir dans la durée. Sans avoir besoin de moi.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- CHIFFRES -->
      <section class="chiffres">
        <div class="container">
          <div class="chiffres-grid">
            <div class="chiffre-bloc">
              <span class="chiffre-n">22</span>
              <span class="chiffre-l">ans d'expérience RH</span>
            </div>
            <div class="chiffre-bloc">
              <span class="chiffre-n">21</span>
              <span class="chiffre-l">établissements de santé dirigés</span>
            </div>
            <div class="chiffre-bloc">
              <span class="chiffre-n">RNCP 6</span>
              <span class="chiffre-l">certification coach</span>
            </div>
          </div>
          <p class="chiffres-lien"><a href="/about">En savoir plus sur le parcours de David →</a></p>
        </div>
      </section>

      <!-- CTA FINAL -->
      <section class="cta-final">
        <div class="container">
          <p class="cta-final-phrase">Un doute. Un projet. Une transition.<br/>Trente minutes pour voir si cet espace est fait pour vous.</p>
          <a href="https://calendly.com/david-delord-m2p-coaching/30min" target="_blank" rel="noopener" class="cta">
            Envie d'en savoir plus ? 30 minutes suffisent.
          </a>
          <p class="cta-note">Sans engagement · Visio ou présentiel Occitanie</p>
        </div>
      </section>

      <ContactForm />

    </main>
    <Footer />
  </body>
</html>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var Q = [
    { q: "Quelle situation vous rejoint le plus ?", opts: [
      { t: "Je gere, mais je ne sais plus tres bien pourquoi.", s: [2,1,0,0] },
      { t: "Je porte l'institution. Personne ne me porte.", s: [0,3,0,0] },
      { t: "Mes managers ont besoin d'un espace que je ne peux pas leur donner.", s: [0,0,3,0] },
      { t: "J'ai une direction. Je veux mettre toutes les chances de mon cote.", s: [0,0,0,3] }
    ]},
    { q: "Votre principale source de tension ?", opts: [
      { t: "La prise de decision sous pression constante", s: [2,2,0,0] },
      { t: "Le sentiment de ne pas etre a ma place", s: [3,0,0,0] },
      { t: "Trouver les bons leviers pour mes equipes", s: [0,1,3,0] },
      { t: "Une envie de passer a l'etape suivante", s: [0,0,0,3] }
    ]},
    { q: "Si vous pouviez changer une chose des demain ?", opts: [
      { t: "Retrouver de la clarte sur ma trajectoire", s: [3,1,0,1] },
      { t: "Avoir un espace pour reflechir", s: [1,3,0,0] },
      { t: "Mieux accompagner les managers", s: [0,0,3,0] },
      { t: "Structurer le projet que j'ai en tete", s: [0,0,0,3] }
    ]},
    { q: "Vous representez plutot...", opts: [
      { t: "Un cadre ou manager en questionnement", s: [5,0,0,0] },
      { t: "Un dirigeant ou directeur d'etablissement", s: [0,5,0,0] },
      { t: "Un DRH ou responsable RH", s: [0,0,5,0] },
      { t: "Quelqu'un avec un projet ou une envie de progresser", s: [0,0,0,5] }
    ]}
  ];
  var P = [
    { tag: "Cadre & Manager", titre: "Vous avez l'expertise. Pas toujours l'espace pour l'exercer.", desc: "Prise de poste, surcharge decisionnelle, questionnement de trajectoire. C'est precisement la qu'un cadre rigoureux fait la difference.", phrase: "De la surcharge a la clarte, puis a une posture que vous tenez dans la duree." },
    { tag: "Dirigeant sante privee", titre: "Vous tenez le systeme. Mais qui tient l'espace pour vous ?", desc: "Vous etes en premiere ligne des injonctions contradictoires. La performance ne peut pas se construire sur l'epuisement.", phrase: "De la saturation institutionnelle a un leadership durable." },
    { tag: "DRH & Organisation", titre: "Vous voyez ce dont vos managers ont besoin.", desc: "Un regard exterieur avec une expertise RH de l'interieur. C'est exactement ce que M2P apporte.", phrase: "Un regard exterieur. Une expertise RH de l'interieur." },
    { tag: "Porteur de projet", titre: "Vous avez un projet. Vous voulez mettre toutes les chances de votre cote.", desc: "Transition choisie, ambition a structurer. Vous etes en mouvement. Le coaching fait la difference entre vouloir et reussir.", phrase: "De la clarte a l'action, puis a la reussite durable." }
  ];
  var cur=0, sc=[0,0,0,0], ans=[-1,-1,-1,-1];
  function render() {
    var q=Q[cur];
    document.getElementById('diag-num').textContent='Question '+(cur+1)+' sur '+Q.length;
    document.getElementById('diag-question').textContent=q.q;
    document.getElementById('diag-bar').style.width=(cur/Q.length*100)+'%';
    var el=document.getElementById('diag-options');
    el.innerHTML='';
    q.opts.forEach(function(o,i){
      var b=document.createElement('button');
      b.className='diag-opt'+(ans[cur]===i?' active':'');
      b.textContent=o.t;
      b.onclick=function(){pick(i);};
      el.appendChild(b);
    });
    document.getElementById('diag-next').disabled=ans[cur]<0;
    document.getElementById('diag-back').style.display=cur>0?'inline-block':'none';
    document.getElementById('diag-next').textContent=cur===Q.length-1?'Voir mon profil':'Continuer';
  }
  function pick(i){
    ans[cur]=i;
    document.querySelectorAll('.diag-opt').forEach(function(b,idx){b.classList.toggle('active',idx===i);});
    document.getElementById('diag-next').disabled=false;
  }
  window.diagNext=function(){
    if(ans[cur]<0)return;
    Q[cur].opts[ans[cur]].s.forEach(function(v,i){sc[i]+=v;});
    if(cur<Q.length-1){cur++;render();}else{showResult();}
  };
  window.diagBack=function(){
    if(cur===0)return;
    Q[cur-1].opts[ans[cur-1]].s.forEach(function(v,i){sc[i]-=v;});
    cur--;render();
  };
  window.diagRestart=function(){
    cur=0;sc=[0,0,0,0];ans=[-1,-1,-1,-1];
    document.getElementById('diag-quiz').style.display='block';
    document.getElementById('diag-result').style.display='none';
    render();
  };
  function showResult(){
    document.getElementById('diag-bar').style.width='100%';
    var best=0;
    sc.forEach(function(v,i){if(v>sc[best])best=i;});
    var p=P[best];
    document.getElementById('diag-tag').textContent=p.tag;
    document.getElementById('diag-rtitle').textContent=p.titre;
    document.getElementById('diag-rdesc').textContent=p.desc;
    document.getElementById('diag-rphrase').textContent=p.phrase;
    document.getElementById('diag-quiz').style.display='none';
    document.getElementById('diag-result').style.display='block';
  }
  render();
});
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; }
  img { display: block; max-width: 100%; height: auto; }

  :root {
    --kaki: #2C3028;
    --kaki-p: #1e2419;
    --or: #C18E52;
    --or-p: #b8975a;
    --creme: #F4F1EA;
    --sage: #6E8774;
    --texte: #4A4F4B;
    --blanc: #ffffff;
  }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

  .section-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--sage);
    font-weight: 600;
    margin-bottom: 1rem;
    display: block;
  }

  /* HERO */
  .hero { background: var(--kaki); color: var(--creme); overflow: hidden; }
  .hero-inner { max-width: 1100px; margin: 0 auto; display: flex; flex-direction: column; }
  .hero-photo-wrap { position: relative; width: 100%; order: -1; }
  .hero-photo { width: 100%; height: 320px; object-fit: cover; object-position: center 20%; }
  .hero-badge { position: absolute; bottom: 1rem; right: 1rem; background: var(--or); color: #fff; padding: 0.5rem 0.85rem; border-radius: 4px; text-align: center; line-height: 1.3; }
  .badge-titre { display: block; font-size: 0.8rem; font-weight: 700; }
  .badge-sous { display: block; font-size: 0.7rem; opacity: 0.85; }
  .hero-texte { padding: 2.5rem 1.5rem 3rem; order: 1; }
  .surtitre { font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--or); margin-bottom: 1rem; display: block; }
  .hero h1 { font-size: 2.2rem; font-weight: 700; line-height: 1.12; color: var(--creme); margin-bottom: 1.25rem; }
  .sous-titre { font-size: 1rem; color: #C8C4B8; margin-bottom: 2rem; font-style: italic; line-height: 1.6; }
  .cta { display: block; background: var(--or); color: #fff; padding: 1rem 1.5rem; border-radius: 4px; text-decoration: none; font-weight: 600; font-size: 0.95rem; text-align: center; transition: background 0.2s; }
  .cta:hover { background: #a97a42; color: #fff; }
  .cta-note { font-size: 0.75rem; color: #9A9590; text-align: center; margin-top: 0.6rem; }

  /* DIAGNOSTIC */
  .diagnostic { background: var(--kaki-p); padding: 5rem 1.5rem; }
  .diagnostic .section-label { color: var(--or-p); }
  .diag-wrap { max-width: 620px; margin: 0 auto; }
  .diag-header { background: rgba(255,255,255,0.05); border: 1px solid rgba(184,151,90,0.2); border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem; }
  .diag-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--or-p); font-weight: 600; margin-bottom: 0.35rem; display: block; }
  .diag-titre { font-size: 1.1rem; font-weight: 700; color: var(--creme); margin: 0; }
  .diag-progress { height: 3px; background: rgba(184,151,90,0.2); border-radius: 2px; margin-top: 1rem; }
  .diag-progress div { height: 100%; width: 0; background: var(--or); border-radius: 2px; transition: width 0.4s; }
  .diag-num { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--sage); font-weight: 600; margin-bottom: 0.5rem; }
  .diag-question { font-size: 1.05rem; font-weight: 600; color: var(--creme); line-height: 1.4; margin-bottom: 1rem; }
  .diag-options { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.25rem; }
  .diag-opt { background: rgba(255,255,255,0.05); border: 1px solid rgba(184,151,90,0.2); border-radius: 6px; padding: 0.85rem 1rem; cursor: pointer; font-size: 0.92rem; color: #C8C4B8; text-align: left; line-height: 1.45; width: 100%; transition: border-color 0.15s, background 0.15s; }
  .diag-opt:hover { border-color: var(--or); background: rgba(193,142,82,0.1); }
  .diag-opt.active { border-color: var(--or); background: var(--or); color: #fff; }
  .diag-nav { display: flex; gap: 0.75rem; }
  .diag-btn-next { flex: 1; background: var(--or); color: #fff; border: none; border-radius: 6px; padding: 0.8rem 1.25rem; font-size: 0.92rem; font-weight: 600; cursor: pointer; transition: background 0.2s; }
  .diag-btn-next:hover { background: #a97a42; }
  .diag-btn-next:disabled { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.3); cursor: not-allowed; }
  .diag-btn-back { display: none; background: transparent; border: 1px solid rgba(184,151,90,0.3); border-radius: 6px; padding: 0.8rem 1rem; font-size: 0.88rem; color: var(--or-p); cursor: pointer; }
  .diag-result-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(184,151,90,0.3); border-radius: 8px; padding: 1.75rem 1.5rem; margin-bottom: 1rem; }
  .diag-tag { display: inline-block; background: var(--or); color: #fff; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 3px 10px; border-radius: 4px; margin-bottom: 0.85rem; }
  .diag-rtitle { font-size: 1.05rem; font-weight: 700; color: var(--creme); line-height: 1.3; margin-bottom: 0.75rem; }
  .diag-rdesc { font-size: 0.9rem; color: #b0a898; line-height: 1.75; margin-bottom: 1.25rem; }
  .diag-rphrase { border-left: 2px solid var(--or); padding-left: 0.75rem; font-size: 0.88rem; color: var(--or-p); font-style: italic; line-height: 1.6; margin: 0; }
  .diag-cta { display: block; background: var(--or); color: #fff; padding: 1rem 1.5rem; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.95rem; text-align: center; margin-top: 1rem; transition: background 0.2s; }
  .diag-cta:hover { background: #a97a42; color: #fff; }
  .diag-cta-note { font-size: 0.72rem; color: #7A7570; text-align: center; margin: 0.5rem 0 0; }
  .diag-restart { display: block; width: 100%; background: transparent; border: 1px solid rgba(184,151,90,0.3); border-radius: 6px; padding: 0.7rem; font-size: 0.88rem; color: var(--or-p); cursor: pointer; margin-top: 0.75rem; }

  /* MÉTHODE */
  .methode { background: var(--creme); padding: 5rem 1.5rem; }
  .methode h2 { font-size: 1.8rem; color: var(--kaki); margin-bottom: 3rem; line-height: 1.2; }
  .m2p-trio { display: flex; flex-direction: column; gap: 2rem; align-items: center; }
  .m2p-item { text-align: center; max-width: 260px; }
  .m2p-cercle { width: 72px; height: 72px; border-radius: 50%; border: 2px solid var(--or); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; font-weight: 700; color: var(--or); margin: 0 auto 1rem; }
  .m2p-item h3 { color: var(--kaki); font-size: 1.1rem; margin-bottom: 0.5rem; }
  .m2p-item p { color: var(--texte); font-size: 0.92rem; line-height: 1.6; margin: 0; }
  .m2p-fleche { font-size: 1.5rem; color: var(--or); transform: rotate(90deg); }

  /* CHIFFRES */
  .chiffres { background: var(--kaki); padding: 5rem 1.5rem; }
  .chiffres-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; max-width: 800px; margin: 0 auto; }
  .chiffre-bloc { text-align: center; }
  .chiffre-n { display: block; font-size: 3rem; font-weight: 700; color: var(--or); line-height: 1; margin-bottom: 0.5rem; }
  .chiffre-l { display: block; font-size: 0.85rem; color: #C8C4B8; text-transform: uppercase; letter-spacing: 0.08em; }
  .chiffres-lien { text-align: center; margin-top: 3rem; }
  .chiffres-lien a { color: var(--or-p); font-size: 0.9rem; text-decoration: none; border-bottom: 1px solid rgba(184,151,90,0.3); padding-bottom: 2px; }
  .chiffres-lien a:hover { border-color: var(--or); color: var(--or); }

  /* CTA FINAL */
  .cta-final { background: var(--kaki-p); padding: 6rem 1.5rem; text-align: center; }
  .cta-final-phrase { font-size: 1.3rem; color: var(--creme); margin-bottom: 2rem; line-height: 1.6; font-style: italic; }
  .cta-final .cta { display: inline-block; width: auto; padding: 1rem 2.5rem; }
  .cta-final .cta-note { text-align: center; }

  /* RESPONSIVE */
  @media (min-width: 860px) {
    .hero-inner { flex-direction: row; align-items: stretch; min-height: 560px; }
    .hero-texte { flex: 1; padding: 5rem 4rem 5rem 2rem; display: flex; flex-direction: column; justify-content: center; order: 0; }
    .hero-photo-wrap { width: 400px; flex-shrink: 0; order: 1; }
    .hero-photo { width: 100%; height: 100%; object-position: center 15%; }
    .hero h1 { font-size: 3rem; }
    .cta { display: inline-block; width: auto; padding: 1rem 2rem; }
    .cta-note { text-align: left; }
    .m2p-trio { flex-direction: row; align-items: flex-start; justify-content: center; gap: 1rem; }
    .m2p-fleche { transform: rotate(0deg); margin-top: 2rem; }
    .chiffres-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>