---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const SITE_TITLE = "David Delord · Coach Certifié RNCP 6 | M²P Coaching";
const SITE_DESCRIPTION = "22 ans de terrain RH, dont responsable RH recrutement d'un groupe de santé privée de 21 établissements. Aujourd'hui coach certifié. C'est ça qui change tout.";
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <!-- ════════════════════════════════
           HERO ABOUT — sobre, textuel
           ════════════════════════════════ -->
      <section class="about-hero">
        <div class="container">
          <p class="label">David Delord</p>
          <h1>22 ans de terrain RH.<br/> Aujourd'hui coach certifié.<br/> C'est ça qui change tout.</h1>
          <p class="hero-sous">Je ne viens pas du monde du coaching. Je viens du terrain. C'est ce qui change tout.</p>
        </div>
      </section>

      <!-- ════════════════════════════════
           SECTION PHILOSOPHIE
           ════════════════════════════════ -->
      <section class="philosophie">
        <div class="container philo-grid">

          <div class="philo-texte">
            <p class="label">Ma philosophie</p>
            <h2>Je suis architecte du cadre. Pas conseiller.</h2>
            <p>Mon approche est humaniste non-directive. Ce que cela signifie concrètement : je ne vous dis pas quoi faire. Je ne trace pas votre chemin. Je construis l'espace dans lequel vous retrouvez votre propre puissance d'agir.</p>
            <p>Ma conviction profonde : vous avez déjà les ressources. Ce qui manque, c'est un cadre rigoureux pour les mobiliser — sans la pression du quotidien, sans l'injonction de performance immédiate, sans avoir à justifier chaque doute.</p>
            <p>La réussite de mon intervention se mesure à un seul indicateur : à la fin du parcours, vous n'avez plus besoin de moi.</p>
          </div>

          <div class="philo-citation">
            <blockquote>
              <p>"Je ne décide pas à votre place. Je crée le cadre dans lequel vous trouvez votre direction."</p>
            </blockquote>
            <div class="philo-valeurs">
              <div class="valeur-item">
                <span class="valeur-dot"></span>
                <span>Primauté de l'individu sur le système</span>
              </div>
              <div class="valeur-item">
                <span class="valeur-dot"></span>
                <span>Autonomie comme horizon, pas comme point de départ</span>
              </div>
              <div class="valeur-item">
                <span class="valeur-dot"></span>
                <span>Étanchéité absolue entre la séance et l'institution</span>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ════════════════════════════════
           PARCOURS RH CHRONOLOGIQUE
           ════════════════════════════════ -->
      <section class="parcours">
        <div class="container">
          <p class="label label-gold">Parcours</p>
          <h2>22 ans de terrain. Avant d'être coach, j'étais de l'autre côté.</h2>
          <p class="parcours-intro">J'ai démarré ma carrière comme chargé de recrutement chez Randstad en 2002. Consultant senior, puis responsable d'agence. Vingt ans à comprendre les organisations de l'intérieur, à travailler avec des cadres dans des environnements exigeants. Ce que j'y ai appris ne s'enseigne pas en formation.</p>

          <div class="timeline">

            <div class="tl-item">
              <div class="tl-marqueur">
                <div class="tl-point"></div>
                <div class="tl-ligne"></div>
              </div>
              <div class="tl-contenu">
                <p class="tl-periode">2002 — 2010</p>
                <h3>Les fondations RH · Randstad</h3>
                <p>Chargé de recrutement. Construction progressive d'une expertise terrain : sourcing, évaluation, accompagnement des candidats et des clients. Apprentissage des codes, des tensions, des non-dits des organisations.</p>
              </div>
            </div>

            <div class="tl-item">
              <div class="tl-marqueur">
                <div class="tl-point"></div>
                <div class="tl-ligne"></div>
              </div>
              <div class="tl-contenu">
                <p class="tl-periode">2010 — 2021</p>
                <h3>Consultant Senior · Randstad</h3>
                <p>Accompagnement de clients sur des enjeux RH complexes. Développement d'une lecture fine des organisations et de leurs dynamiques humaines. Travail au quotidien avec des cadres et managers dans des environnements exigeants.</p>
              </div>
            </div>

            <div class="tl-item">
              <div class="tl-marqueur">
                <div class="tl-point"></div>
                <div class="tl-ligne"></div>
              </div>
              <div class="tl-contenu">
                <p class="tl-periode">2021 — 2023</p>
                <h3>Responsable d'Agence · Randstad</h3>
                <p>Pilotage d'une agence, management d'équipe, développement commercial et gestion des relations clients. Responsabilité d'un centre de profit avec des objectifs de performance et de satisfaction client.</p>
              </div>
            </div>

            <div class="tl-item">
              <div class="tl-marqueur">
                <div class="tl-point"></div>
                <div class="tl-ligne"></div>
              </div>
              <div class="tl-contenu">
                <p class="tl-periode">2023 — 2025</p>
                <h3>Responsable RH Recrutement & Développement · Clinipole</h3>
                <p>Groupe de santé privée de 21 établissements. Refonte complète des politiques de recrutement du groupe. Travail sur l'attractivité, la marque employeur, la QVT et la politique handicap. Environ 250 recrutements par an. Ce parcours m'a donné une chose rare : la capacité à lire une organisation, ses tensions et ses enjeux humains, sans qu'on ait besoin de me les expliquer.</p>
              </div>
            </div>

            <div class="tl-item tl-item-final">
              <div class="tl-marqueur">
                <div class="tl-point tl-point-or"></div>
              </div>
              <div class="tl-contenu">
                <p class="tl-periode">Aujourd'hui</p>
                <h3>M²P Coaching & Développement</h3>
                <p>Au fil des années, j'ai occupé une position particulière dans les organisations. Celle de quelqu'un à qui on parle vraiment. Pas la version officielle. La version réelle. J'ai vu des cadres compétents douter en silence. Des dirigeants performants s'isoler progressivement. Des professionnels talentueux avancer sans jamais vraiment choisir leur direction. C'est cette réalité qui m'a amené au coaching. L'envie de créer un espace où ce qui se joue vraiment peut enfin être regardé en face, et transformé en mouvement.</p>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- ════════════════════════════════
           CERTIFICATIONS & ÉTHIQUE
           ════════════════════════════════ -->
      <section class="certifications">
        <div class="container">
          <p class="label">Garanties</p>
          <h2>Une pratique encadrée. Pas une promesse.</h2>
          <p class="certif-intro">Le coaching est un secteur non réglementé. La certification RNCP niveau 6 et l'inscription à une charte éthique ne sont pas des ornements — ce sont les seuls repères objectifs qui permettent de distinguer une pratique sérieuse.</p>

          <div class="certif-grid">

            <div class="certif-card">
              <div class="certif-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="8" r="6"/><path d="M9 13l-2 7 5-3 5 3-2-7"/>
                </svg>
              </div>
              <h3>Certification RNCP Niveau 6</h3>
              <p>Titre professionnel reconnu par l'État, équivalent licence. Référentiel de compétences validé, formation encadrée, jury externe.</p>
            </div>

            <div class="certif-card">
              <div class="certif-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              </div>
              <h3>Pratique supervisée</h3>
              <p>Supervision régulière par un coach senior. La supervision n'est pas une obligation légale — c'est une exigence éthique que je m'impose pour garantir la qualité de ma pratique.</p>
            </div>

            <div class="certif-card">
              <div class="certif-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </div>
              <h3>Confidentialité absolue</h3>
              <p>Étanchéité totale entre la séance et l'institution. Ce qui se dit en séance reste en séance — y compris dans le cadre des contrats tripartites avec les organisations.</p>
            </div>

            <div class="certif-card">
              <div class="certif-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </div>
              <h3>Charte Éthique du Coaching</h3>
              <p>Engagement formel sur les principes déontologiques de la profession : respect de l'autonomie du client, absence de manipulation, clarté des rôles et des limites d'intervention.</p>
            </div>

          </div>

          <div class="rc-pro">
            <p>SASU · RC Pro souscrite · Siret disponible sur demande</p>
          </div>
        </div>
      </section>

      <!-- ════════════════════════════════
           CTA FINAL
           ════════════════════════════════ -->
      <section class="about-cta">
        <div class="container">
          <p class="cta-accroche">Envie d'en savoir plus ? 30 minutes suffisent.</p>
          <a href="https://calendly.com/david-delord-m2p-coaching/echange-decouverte-30-min-m-p-coaching" target="_blank" rel="noopener" class="cta">
            Je réserve
          </a>
          <p class="cta-note">Sans engagement · Visio ou présentiel Occitanie</p>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; }
  img { display: block; max-width: 100%; }

  :root {
    --kaki:      #2C3028;
    --kaki-p:    #1e2419;
    --or:        #C18E52;
    --or-p:      #b8975a;
    --creme:     #F4F1EA;
    --sage:      #6E8774;
    --texte:     #4A4F4B;
    --blanc:     #ffffff;
    --rayon:     4px;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--sage);
    font-weight: 600;
    margin-bottom: 0.4rem;
    display: block;
  }
  .label-gold { color: var(--or-p); }
  .br-d { display: none; }

  /* ── HERO ── */
  .about-hero {
    background: var(--anthracite);
    color: var(--creme);
    padding: 4rem 1.5rem 3.5rem;
  }
  .about-hero h1 {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.15;
    color: var(--creme);
    margin-bottom: 1.25rem;
  }
  .hero-sous {
    font-size: 1rem;
    color: #C8C4B8;
    line-height: 1.75;
    max-width: 680px;
    font-style: italic;
  }

  /* ── PHILOSOPHIE ── */
  .philosophie {
    background: var(--blanc);
    padding: 4rem 1.5rem;
  }
  .philo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .philo-texte h2 {
    font-size: 1.5rem;
    color: var(--kaki);
    margin-bottom: 1.25rem;
    line-height: 1.25;
  }
  .philo-texte p {
    color: var(--texte);
    line-height: 1.8;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }
  blockquote {
    margin: 0 0 2rem;
    padding: 1.5rem;
    background: var(--anthracite);
    border-radius: var(--rayon);
  }
  blockquote p {
    color: var(--creme);
    font-size: 1.05rem;
    font-style: italic;
    line-height: 1.65;
    margin: 0;
  }
  .philo-valeurs {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .valeur-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--texte);
    line-height: 1.5;
  }
  .valeur-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--or);
    flex-shrink: 0;
    margin-top: 0.45rem;
  }

  /* ── PARCOURS TIMELINE ── */
  .parcours {
    background: var(--creme);
    padding: 4rem 1.5rem;
  }
  .parcours h2 {
    font-size: 1.5rem;
    color: var(--kaki);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }
  .parcours-intro {
    color: var(--texte);
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 3rem;
    max-width: 680px;
  }

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .tl-item {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 0 1.25rem;
  }

  .tl-marqueur {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tl-point {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--or);
    background: var(--creme);
    flex-shrink: 0;
    margin-top: 0.3rem;
  }
  .tl-point-or {
    background: var(--or);
  }

  .tl-ligne {
    flex: 1;
    width: 1.5px;
    background: rgba(193,142,82,0.3);
    margin: 4px 0 0;
    min-height: 2rem;
  }

  .tl-contenu {
    padding-bottom: 2.5rem;
  }

  .tl-item-final .tl-contenu {
    padding-bottom: 0;
  }

  .tl-periode {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--or);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .tl-contenu h3 {
    font-size: 1.05rem;
    color: var(--kaki);
    margin-bottom: 0.5rem;
  }

  .tl-contenu p {
    font-size: 0.92rem;
    color: var(--texte);
    line-height: 1.75;
    margin: 0;
  }

  /* ── CERTIFICATIONS ── */
  .certifications {
    background: var(--blanc);
    padding: 4rem 1.5rem;
  }
  .certifications h2 {
    font-size: 1.5rem;
    color: var(--kaki);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }
  .certif-intro {
    color: var(--texte);
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 2.5rem;
    max-width: 680px;
  }

  .certif-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .certif-card {
    border: 1px solid #e8e4db;
    border-radius: var(--rayon);
    padding: 1.5rem;
    background: var(--blanc);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .certif-icon {
    color: var(--or);
  }

  .certif-card h3 {
    font-size: 1rem;
    color: var(--kaki);
    margin: 0;
  }

  .certif-card p {
    font-size: 0.9rem;
    color: var(--texte);
    line-height: 1.7;
    margin: 0;
  }

  .rc-pro {
    padding-top: 1.25rem;
    border-top: 1px solid #e8e4db;
  }
  .rc-pro p {
    font-size: 0.78rem;
    color: var(--sage);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }

  /* ── CTA FINAL ── */
  .about-cta {
    background: var(--kaki-p);
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .cta-accroche {
    font-size: 1.3rem;
    color: var(--creme);
    margin-bottom: 1.5rem;
    font-style: italic;
    line-height: 1.5;
  }

  .cta {
    display: inline-block;
    background: var(--or);
    color: var(--blanc);
    padding: 1rem 2rem;
    border-radius: var(--rayon);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background 0.2s;
  }
  .cta:hover { background: #a97a42; color: var(--blanc); }

  .cta-note {
    font-size: 0.75rem;
    color: #7A7570;
    margin-top: 0.6rem;
    margin-bottom: 0;
  }

  /* ── RESPONSIVE DESKTOP ── */
 @media (min-width: 860px) {
    .br-d { display: block; }

    .about-hero { padding: 6rem 2rem 5rem; }
    .about-hero h1 { font-size: 2.8rem; }
    .hero-sous { font-size: 1.1rem; }

    .philosophie { padding: 6rem 2rem; }
    .philo-grid {
      grid-template-columns: 1fr 380px;
      gap: 5rem;
      align-items: start;
    }
    .philo-texte h2 { font-size: 1.8rem; }

    .parcours { padding: 6rem 2rem; }
    .parcours h2 { font-size: 1.8rem; }
    .tl-item { grid-template-columns: 48px 1fr; gap: 0 1.75rem; }
    .tl-point { width: 16px; height: 16px; }

    .certifications { padding: 6rem 2rem; }
    .certifications h2 { font-size: 1.8rem; }
    .certif-grid { grid-template-columns: repeat(2, 1fr); }

    .about-cta { padding: 6rem 2rem; }
    .cta-accroche { font-size: 1.5rem; }
  }
</style>