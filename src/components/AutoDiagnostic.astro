---
---

<section class="diagnostic">
  <div class="container">
    <div class="diag-wrap">

      <div class="diag-header">
        <p class="diag-label">Auto-diagnostic</p>
        <p class="diag-titre">Où en êtes-vous vraiment ?</p>
        <div class="progress-bar">
          <div class="progress-fill" id="prog"></div>
        </div>
      </div>

      <div id="quiz">
        <p class="q-numero" id="qnum"></p>
        <p class="q-texte" id="qtexte"></p>
        <div class="options" id="opts"></div>
        <div class="nav">
          <button class="btn-back" id="btn-back" onclick="diagBack()">Retour</button>
          <button class="btn-next" id="btn-next" onclick="diagNext()" disabled>Continuer</button>
        </div>
      </div>

      <div id="result" style="display:none">
        <div class="result-card">
          <span class="result-tag" id="r-tag"></span>
          <p class="result-titre" id="r-titre"></p>
          <p class="result-desc" id="r-desc"></p>
          <p class="result-phrase" id="r-phrase"></p>
        </div>
        <a
          class="cta-result"
          href="https://calendly.com/david-delord-m2p-coaching/30min"
          target="_blank"
          rel="noopener"
        >
          Envie d'en savoir plus ? 30 minutes suffisent.
        </a>
        <p class="cta-note-r">Sans engagement · Visio ou présentiel Occitanie</p>
        <button class="btn-restart" onclick="diagRestart()">Recommencer le diagnostic</button>
      </div>

    </div>
  </div>
</section>

<script>
  const questions = [
    {
      texte: "Quelle phrase vous rejoint le plus aujourd'hui ?",
      opts: [
        { texte: "Je gère. Mais je ne sais plus très bien pourquoi.", score: { cadre: 2, diri: 1, drh: 0, projet: 0 } },
        { texte: "Je porte l'institution. Personne ne me porte.", score: { cadre: 0, diri: 3, drh: 0, projet: 0 } },
        { texte: "Mes managers ont besoin d'un espace que je ne peux pas leur donner.", score: { cadre: 0, diri: 0, drh: 3, projet: 0 } },
        { texte: "J'ai une direction. Je veux mettre toutes les chances de mon côté.", score: { cadre: 0, diri: 0, drh: 0, projet: 3 } }
      ]
    },
    {
      texte: "Votre principale source de tension en ce moment ?",
      opts: [
        { texte: "La prise de décision sous pression constante", score: { cadre: 2, diri: 2, drh: 0, projet: 0 } },
        { texte: "Le sentiment de ne pas être à ma place dans mon rôle", score: { cadre: 3, diri: 0, drh: 0, projet: 0 } },
        { texte: "Trouver les bons leviers pour mes équipes", score: { cadre: 0, diri: 1, drh: 3, projet: 0 } },
        { texte: "Pas de tension — plutôt une envie de passer à l'étape suivante", score: { cadre: 0, diri: 0, drh: 0, projet: 3 } }
      ]
    },
    {
      texte: "Si vous pouviez changer une chose dès demain ?",
      opts: [
        { texte: "Retrouver de la clarté sur ma trajectoire", score: { cadre: 3, diri: 1, drh: 0, projet: 1 } },
        { texte: "Avoir un espace pour réfléchir sans être interrompu", score: { cadre: 1, diri: 3, drh: 0, projet: 0 } },
        { texte: "Mieux accompagner les managers de mon organisation", score: { cadre: 0, diri: 0, drh: 3, projet: 0 } },
        { texte: "Structurer et accélérer le projet que j'ai en tête", score: { cadre: 0, diri: 0, drh: 0, projet: 3 } }
      ]
    },
    {
      texte: "Vous représentez plutôt…",
      opts: [
        { texte: "Un cadre ou manager en questionnement", score: { cadre: 5, diri: 0, drh: 0, projet: 0 } },
        { texte: "Un dirigeant ou directeur d'établissement", score: { cadre: 0, diri: 5, drh: 0, projet: 0 } },
        { texte: "Un DRH ou responsable RH", score: { cadre: 0, diri: 0, drh: 5, projet: 0 } },
        { texte: "Quelqu'un avec un projet ou une envie de progresser", score: { cadre: 0, diri: 0, drh: 0, projet: 5 } }
      ]
    }
  ];

  const profils: Record<string, { tag: string; titre: string; desc: string; phrase: string }> = {
    cadre: {
      tag: "Cadre & Manager",
      titre: "Vous avez l'expertise. Pas toujours l'espace pour l'exercer pleinement.",
      desc: "Prise de poste, surcharge décisionnelle, questionnement de trajectoire — vous avancez, mais sans vraiment choisir votre direction. C'est précisément là qu'un cadre rigoureux fait la différence.",
      phrase: "De la surcharge à la clarté décisionnelle, puis à une posture que vous tenez dans la durée."
    },
    diri: {
      tag: "Dirigeant santé privée",
      titre: "Vous tenez le système. Mais qui tient l'espace pour vous ?",
      desc: "Directeur d'établissement, cadre de direction — vous êtes en première ligne des injonctions contradictoires. La performance institutionnelle ne peut pas se construire sur l'épuisement personnel.",
      phrase: "De la saturation institutionnelle à un leadership qui tient dans la durée."
    },
    drh: {
      tag: "DRH & Organisation",
      titre: "Vous voyez ce dont vos managers ont besoin. Il vous faut le bon partenaire.",
      desc: "Vous cherchez un accompagnement externe pour vos managers promus ou vos cadres en difficulté — un regard extérieur avec une expertise RH de l'intérieur.",
      phrase: "Un regard extérieur. Une expertise RH de l'intérieur."
    },
    projet: {
      tag: "Porteur de projet",
      titre: "Vous avez un projet. Vous voulez mettre toutes les chances de votre côté.",
      desc: "Transition choisie, ambition à structurer, envie de progresser — vous n'êtes pas en difficulté, vous êtes en mouvement. Le coaching, c'est ce qui fait la différence entre vouloir et réussir.",
      phrase: "De la clarté à l'action, puis de l'action à la réussite durable."
    }
  };

  let current = 0;
  let scores: Record<string, number> = { cadre: 0, diri: 0, drh: 0, projet: 0 };
  let answers: (number | null)[] = new Array(questions.length).fill(null);

  function diagRender() {
    const q = questions[current];
    const qnum = document.getElementById('qnum');
    const qtexte = document.getElementById('qtexte');
    const prog = document.getElementById('prog');
    const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
    const btnBack = document.getElementById('btn-back') as HTMLButtonElement;
    const optsEl = document.getElementById('opts');

    if (!qnum || !qtexte || !prog || !btnNext || !btnBack || !optsEl) return;

    qnum.textContent = `Question ${current + 1} sur ${questions.length}`;
    qtexte.textContent = q.texte;
    prog.style.width = (current / questions.length * 100) + '%';

    optsEl.innerHTML = '';
    q.opts.forEach((o, i) => {
      const btn = document.createElement('button');
      btn.className = 'diag-opt' + (answers[current] === i ? ' selected' : '');
      btn.textContent = o.texte;
      btn.addEventListener('click', () => diagSelect(i));
      optsEl.appendChild(btn);
    });

    btnNext.disabled = answers[current] === null;
    btnBack.style.display = current > 0 ? 'inline-block' : 'none';
    btnNext.textContent = current === questions.length - 1 ? 'Voir mon profil' : 'Continuer';
  }

  function diagSelect(i: number) {
    answers[current] = i;
    document.querySelectorAll('.diag-opt').forEach((b, idx) => {
      b.classList.toggle('selected', idx === i);
    });
    const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
    if (btnNext) btnNext.disabled = false;
  }

  function diagNext() {
    if (answers[current] === null) return;
    const s = questions[current].opts[answers[current]!].score;
    Object.keys(scores).forEach(k => scores[k] += s[k as keyof typeof s]);
    if (current < questions.length - 1) {
      current++;
      diagRender();
    } else {
      diagShowResult();
    }
  }

  function diagBack() {
    if (current === 0) return;
    const s = questions[current - 1].opts[answers[current - 1]!].score;
    Object.keys(scores).forEach(k => scores[k] -= s[k as keyof typeof s]);
    current--;
    diagRender();
  }

  function diagShowResult() {
    const prog = document.getElementById('prog');
    if (prog) prog.style.width = '100%';
    const top = Object.entries(scores).sort((a, b) => b[1] - a[1])[0][0];
    const p = profils[top];
    const rTag = document.getElementById('r-tag');
    const rTitre = document.getElementById('r-titre');
    const rDesc = document.getElementById('r-desc');
    const rPhrase = document.getElementById('r-phrase');
    if (rTag) rTag.textContent = p.tag;
    if (rTitre) rTitre.textContent = p.titre;
    if (rDesc) rDesc.textContent = p.desc;
    if (rPhrase) rPhrase.textContent = p.phrase;
    const quiz = document.getElementById('quiz');
    const result = document.getElementById('result');
    if (quiz) quiz.style.display = 'none';
    if (result) result.style.display = 'block';
  }

  function diagRestart() {
    current = 0;
    scores = { cadre: 0, diri: 0, drh: 0, projet: 0 };
    answers = new Array(questions.length).fill(null);
    const quiz = document.getElementById('quiz');
    const result = document.getElementById('result');
    if (quiz) quiz.style.display = 'block';
    if (result) result.style.display = 'none';
    diagRender();
  }

  (window as any).diagNext = diagNext;
  (window as any).diagBack = diagBack;
  (window as any).diagRestart = diagRestart;

  diagRender();
</script>

<style>
  .diagnostic {
    background: #F4F1EA;
    padding: 4rem 1.5rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .diag-wrap {
    max-width: 620px;
    margin: 0 auto;
  }

  .diag-header {
    background: #2C3028;
    border-radius: 8px;
    padding: 1.5rem 1.5rem 1.25rem;
    margin-bottom: 1.5rem;
  }

  .diag-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #b8975a;
    font-weight: 600;
    margin-bottom: 0.35rem;
    display: block;
  }

  .diag-titre {
    font-size: 1.2rem;
    font-weight: 700;
    color: #F4F1EA;
    line-height: 1.3;
    margin: 0;
  }

  .progress-bar {
    height: 3px;
    background: rgba(184,151,90,0.2);
    border-radius: 2px;
    margin-top: 1rem;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: #C18E52;
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  .q-numero {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6E8774;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .q-texte {
    font-size: 1.05rem;
    font-weight: 600;
    color: #2C3028;
    line-height: 1.4;
    margin-bottom: 1rem;
  }

  .options {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .diag-opt {
    background: #fff;
    border: 1.5px solid #e8e4db;
    border-radius: 6px;
    padding: 0.85rem 1rem;
    cursor: pointer;
    font-size: 0.92rem;
    color: #4A4F4B;
    text-align: left;
    transition: border-color 0.15s, background 0.15s;
    line-height: 1.45;
    width: 100%;
  }

  .diag-opt:hover {
    border-color: #C18E52;
    background: #faf8f4;
  }

  .diag-opt.selected {
    border-color: #C18E52;
    background: #2C3028;
    color: #F4F1EA;
  }

  .nav {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .btn-next {
    flex: 1;
    background: #C18E52;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 0.8rem 1.25rem;
    font-size: 0.92rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-next:hover { background: #a97a42; }

  .btn-next:disabled {
    background: #d4cfc6;
    cursor: not-allowed;
  }

  .btn-back {
    display: none;
    background: transparent;
    border: 1.5px solid #d4cfc6;
    border-radius: 6px;
    padding: 0.8rem 1rem;
    font-size: 0.88rem;
    color: #6E8774;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .btn-back:hover { border-color: #6E8774; }

  .result-card {
    background: #2C3028;
    border-radius: 8px;
    padding: 1.75rem 1.5rem;
    margin-bottom: 1rem;
  }

  .result-tag {
    display: inline-block;
    background: #C18E52;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 0.85rem;
  }

  .result-titre {
    font-size: 1.1rem;
    font-weight: 700;
    color: #F4F1EA;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .result-desc {
    font-size: 0.9rem;
    color: #b0a898;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  .result-phrase {
    border-left: 2px solid #C18E52;
    padding-left: 0.75rem;
    font-size: 0.88rem;
    color: #b8975a;
    font-style: italic;
    line-height: 1.6;
    margin: 0;
  }

  .cta-result {
    display: block;
    width: 100%;
    background: #C18E52;
    color: #fff;
    padding: 1rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    text-align: center;
    transition: background 0.2s;
    box-sizing: border-box;
  }

  .cta-result:hover { background: #a97a42; color: #fff; }

  .cta-note-r {
    font-size: 0.72rem;
    color: #9A9590;
    text-align: center;
    margin: 0.5rem 0 0;
  }

  .btn-restart {
    display: block;
    width: 100%;
    background: transparent;
    border: 1.5px solid #d4cfc6;
    border-radius: 6px;
    padding: 0.7rem;
    font-size: 0.88rem;
    color: #6E8774;
    cursor: pointer;
    margin-top: 0.75rem;
    transition: border-color 0.2s;
  }

  .btn-restart:hover { border-color: #6E8774; }

  @media (min-width: 700px) {
    .diagnostic { padding: 5rem 2rem; }
    .diag-opt { font-size: 0.95rem; }
    .q-texte { font-size: 1.1rem; }
  }
</style>
