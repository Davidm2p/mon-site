---
---

<section class="contact-form-section">
  <div class="contact-form-container">

    <div class="contact-form-left">
      <p class="contact-surtitre">CONTACT</p>
      <h2>Parlons de votre situation.</h2>
      <p class="contact-intro">Remplissez ce formulaire ou réservez directement un échange de 30 minutes. Je vous réponds sous 48h ouvrées.</p>

      <form
        id="contact-form"
        action="https://formspree.io/f/mbderpke"
        method="POST"
      >
        <div class="form-group">
          <label for="name">Nom et prénom *</label>
          <input type="text" id="name" name="name" required placeholder="Votre nom" />
        </div>

        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required placeholder="votre@email.fr" />
        </div>

        <div class="form-group">
          <label for="fonction">Fonction</label>
          <input type="text" id="fonction" name="fonction" placeholder="Ex : Directeur d'établissement, DRH, Manager..." />
        </div>

        <div class="form-group">
          <label for="message">Votre situation *</label>
          <textarea id="message" name="message" required rows="5" placeholder="Décrivez brièvement ce que vous traversez et ce que vous cherchez..."></textarea>
        </div>

        <button type="submit" class="form-submit">Envoyer ma demande</button>
        <p class="form-mention">* Champs obligatoires · Vos données restent strictement confidentielles</p>

        <div id="form-success" class="form-success" style="display:none;">
          Votre message a bien été envoyé. Je vous réponds sous 48h ouvrées.
        </div>
        <div id="form-error" class="form-error" style="display:none;">
          Une erreur s'est produite. Merci de réessayer ou de me contacter directement par email.
        </div>
      </form>
    </div>

    <div class="contact-form-right">
      <div class="contact-info-bloc">
        <p class="contact-info-label">DISPONIBILITÉ</p>
        <p>Visio France entière</p>
        <p>Présentiel Occitanie</p>
      </div>

      <div class="contact-info-bloc">
        <p class="contact-info-label">RÉPONSE</p>
        <p>Sous 48h ouvrées</p>
      </div>

      <hr class="contact-separator" />

      <p class="contact-ou">Ou réservez directement un créneau :</p>
      <a
        href="https://thecoachpilot.com/book/david-delord/echange-decouverte-30-min-m-p-coaching"
        target="_blank"
        rel="noopener"
        class="contact-cta-direct"
      >Je réserve</a>
    </div>

  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' }
        });

        if (response.ok) {
          form.reset();
          if (successMsg) successMsg.style.display = 'block';
          if (errorMsg) errorMsg.style.display = 'none';
        } else {
          if (errorMsg) errorMsg.style.display = 'block';
          if (successMsg) successMsg.style.display = 'none';
        }
      } catch {
        if (errorMsg) errorMsg.style.display = 'block';
        if (successMsg) successMsg.style.display = 'none';
      }
    });
  }
</script>

<style>
  .contact-form-section {
    background: #F4F1EA;
    padding: 5rem 2rem;
  }

  .contact-form-container {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    align-items: start;
  }

  .contact-surtitre {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: #C99763;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .contact-form-left h2 {
    font-size: 1.6rem;
    font-weight: 700;
    color: #535861;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .contact-intro {
    font-size: 0.95rem;
    color: #535861;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #535861;
    margin-bottom: 0.4rem;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid #d8d3c8;
    border-radius: 4px;
    background: #fff;
    font-size: 0.95rem;
    color: #535861;
    font-family: 'Inter', sans-serif;
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #C99763;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    width: 100%;
    background: #C99763;
    color: #fff;
    border: none;
    padding: 1rem 2rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background 0.2s;
    font-family: 'Inter', sans-serif;
  }

  .form-submit:hover {
    background: #a07d45;
  }

  .form-mention {
    font-size: 0.78rem;
    color: #7F9B88;
    margin-top: 0.75rem;
    text-align: center;
  }

  .form-success {
    margin-top: 1rem;
    padding: 1rem 1.25rem;
    background: #eaf2ed;
    border-left: 3px solid #7F9B88;
    border-radius: 4px;
    font-size: 0.9rem;
    color: #3a5c45;
  }

  .form-error {
    margin-top: 1rem;
    padding: 1rem 1.25rem;
    background: #fdf0f0;
    border-left: 3px solid #c0392b;
    border-radius: 4px;
    font-size: 0.9rem;
    color: #c0392b;
  }

  .contact-info-bloc {
    margin-bottom: 1.5rem;
  }

  .contact-info-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: #C99763;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .contact-info-bloc p {
    font-size: 0.92rem;
    color: #535861;
    margin: 0.1rem 0;
  }

  .contact-separator {
    border: none;
    border-top: 1px solid #d8d3c8;
    margin: 1.5rem 0;
  }

  .contact-ou {
    font-size: 0.88rem;
    color: #535861;
    margin-bottom: 0.75rem;
  }

  .contact-cta-direct {
    display: block;
    text-align: center;
    background: transparent;
    border: 2px solid #C99763;
    color: #C99763;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .contact-cta-direct:hover {
    background: #C99763;
    color: #fff;
  }

  @media (max-width: 768px) {
    .contact-form-section {
      padding: 3rem 1.25rem;
    }
    .contact-form-container {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .contact-form-right {
      order: -1;
    }
  }
</style>
