---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a href="/" style="background: transparent; display: flex; align-items: center;">
			<img src="/logo.png" alt="M²P Coaching & Développement" style="height: 80px; width: auto;" />
		</a>

		<div class="internal-links" id="nav-menu">
			<HeaderLink href="/">Accueil</HeaderLink>
			<HeaderLink href="/about">David Delord</HeaderLink>
			<HeaderLink href="/sante-privee">Hospitalisation privée</HeaderLink>
			<HeaderLink href="/accompagnements">Accompagnements</HeaderLink>
			https://thecoachpilot.com/book/david-delord/echange-decouverte-30-min-m-p-coaching
		</div>

		<button class="hamburger" id="hamburger" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="nav-menu">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</nav>
</header>

<script>
  const btn = document.getElementById('hamburger') as HTMLButtonElement | null;
  const menu = document.getElementById('nav-menu') as HTMLElement | null;

  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('open');
      btn.classList.toggle('open');
      btn.setAttribute('aria-expanded', isOpen.toString());
    });

    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('open');
        btn.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>

<style>
header {
  margin: 0;
  padding: 0 1.5em;
  background: #F4F1EA;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  position: relative;
  z-index: 100;
}
nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72px;
}
.internal-links {
  display: flex;
  align-items: center;
  gap: 2rem;
}
.internal-links a {
  color: rgba(45,51,40,0.7);
  text-decoration: none;
  font-size: 0.88rem;
  letter-spacing: 0.01em;
  transition: color 0.2s;
}
.internal-links a:hover,
.internal-links a[aria-current="page"] {
  color: #2d3328;
}
.cta-nav {
  background: #C18E52;
  color: #fff !important;
  padding: 0.55rem 1.25rem;
  border-radius: 3px;
  font-size: 0.85rem;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.2s;
}
.cta-nav:hover {
  background: #a97a42 !important;
  color: #fff !important;
}

/* ── Hamburger button ── */
.hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 40px;
  height: 40px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 4px;
  z-index: 200;
}
.hamburger span {
  display: block;
  width: 24px;
  height: 2px;
  background: #2d3328;
  border-radius: 2px;
  transition: transform 0.3s, opacity 0.3s;
  transform-origin: center;
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── Responsive ── */
@media (max-width: 768px) {
  .hamburger {
    display: flex;
  }

  .internal-links {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    position: absolute;
    top: 72px;
    left: 0;
    right: 0;
    background: #F4F1EA;
    border-top: 1px solid rgba(45,51,40,0.1);
    padding: 1rem 1.5rem 1.5rem;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  .internal-links.open {
    display: flex;
  }

  .internal-links a {
    width: 100%;
    padding: 0.75rem 0;
    font-size: 1rem;
    border-bottom: 1px solid rgba(45,51,40,0.07);
  }

  .internal-links a:last-child {
    border-bottom: none;
  }

  .cta-nav {
    margin-top: 0.75rem;
    width: 100%;
    text-align: center;
    padding: 0.75rem 1.25rem;
    font-size: 0.95rem;
  }
}
</style>