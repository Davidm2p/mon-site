---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a href="/" style="background: transparent; display: flex; align-items: center;">
			<img src="/logo.png" alt="M²P Coaching & Développement" style="height: 80px; width: auto; mix-blend-mode: screen;" />
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Accueil</HeaderLink>
			<HeaderLink href="/about">David Delord</HeaderLink>
			<HeaderLink href="/sante-privee">Santé privée</HeaderLink>
			<HeaderLink href="/accompagnements">Accompagnements</HeaderLink>
			<a href="https://calendly.com/david-delord-m2p-coaching/30min" target="_blank" class="cta-nav">Réserver 30 min</a>
		</div>
	</nav>
</header>

<style>
header {
  margin: 0;
  padding: 0 1.5em;
  background: #2d3328;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72px;
}
.internal-links {
  display: flex;
  align-items: center;
  gap: 2rem;
}
.internal-links a {
  color: rgba(245,242,235,0.75);
  text-decoration: none;
  font-size: 0.88rem;
  letter-spacing: 0.01em;
  transition: color 0.2s;
}
.internal-links a:hover,
.internal-links a[aria-current="page"] {
  color: #f5f2eb;
}
.cta-nav {
  background: #C18E52;
  color: #fff !important;
  padding: 0.55rem 1.25rem;
  border-radius: 3px;
  font-size: 0.85rem;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.2s;
}
.cta-nav:hover {
  background: #a97a42 !important;
  color: #fff !important;
}	
</style>