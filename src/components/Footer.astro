---
const today = new Date();
---

<!-- Bouton retour en haut -->
<button id="back-to-top" aria-label="Retour en haut de page">
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="18 15 12 9 6 15"></polyline>
  </svg>
</button>

<footer>
  <div class="footer-inner">
    <p class="footer-copy">© {today.getFullYear()} M²P Coaching & Développement<br/>SASU · RC Pro</p>
    <p class="footer-contact">
      David Delord
      <span class="footer-sep">·</span>
      <a href="tel:+33675747456">06 75 74 74 56</a>
      <span class="footer-sep">·</span>
      <a href="mailto:david.delord@m2p-coaching.fr">david.delord@m2p-coaching.fr</a>
    </p>
    <p class="footer-linkedin">
      <a href="https://www.linkedin.com/in/david-delord-m2p-coaching" target="_blank" rel="noopener" class="linkedin-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn — David Delord
      </a>
    </p>
  </div>
</footer>

<script>
  const btn = document.getElementById('back-to-top') as HTMLButtonElement | null;
  if (btn) {
    window.addEventListener('scroll', () => {
      btn.classList.toggle('visible', window.scrollY > 400);
    });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<style>
  footer {
    background: #1e2219;
    color: #888;
    text-align: center;
    padding: 2.5rem 1.5rem;
    font-size: 0.85rem;
    line-height: 1.8;
  }

  .footer-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .footer-copy {
    color: #666;
    margin-bottom: 0.5rem;
    font-size: 0.82rem;
  }

  .footer-contact {
    margin-bottom: 0.75rem;
    color: #888;
    font-size: 0.85rem;
  }

  .footer-sep {
    margin: 0 0.3rem;
    color: #555;
  }

  footer a {
    color: #b8975a;
    text-decoration: none;
  }

  footer a:hover {
    color: #d4b87a;
  }

  .footer-linkedin {
    margin-top: 0.25rem;
  }

  .linkedin-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #b8975a !important;
    font-size: 0.8rem;
    letter-spacing: 0.03em;
  }

  .linkedin-link svg {
    flex-shrink: 0;
  }

  /* ── Bouton retour en haut ── */
  #back-to-top {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #C18E52;
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s, transform 0.3s;
    pointer-events: none;
    z-index: 999;
  }

  #back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  #back-to-top:hover { background: #a97a42; }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    footer {
      padding: 2rem 1.25rem;
    }

    .footer-contact {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
    }

    .footer-sep {
      display: none;
    }

    #back-to-top {
      bottom: 1.25rem;
      right: 1.25rem;
      width: 44px;
      height: 44px;
    }
  }
</style>